# PostgreSQL deployment profile
SPRING_PROFILES_ACTIVE=postgres

# Use one database per shop deployment.
# For Railway Postgres, set these from that project's database service.
DB_HOST=
DB_PORT=5432
DB_NAME=hdisla3tak
DB_USERNAME=
DB_PASSWORD=

# One uploads volume per shop deployment
APP_STORAGE_UPLOAD_DIR=/app/uploads/items

# Public base URL for tracking links and SMS compose links
# On Railway you can set:
# APP_SMS_BASE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
APP_SMS_BASE_URL=

APP_NOTIFICATIONS_ENABLED=false
APP_NOTIFICATIONS_PROVIDER=log
APP_NOTIFICATIONS_WHATSAPP_FROM=whatsapp:+14155238886
APP_NOTIFICATIONS_TWILIO_ACCOUNT_SID=
APP_NOTIFICATIONS_TWILIO_AUTH_TOKEN=
